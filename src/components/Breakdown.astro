---
import { landing } from '../content/landing';
---

<section class="section-shell breakdown">
  <div>
    <p class="eyebrow">Не симптом, а причина</p>
    <h2>{landing.breakdown.title}</h2>
    <p>{landing.breakdown.intro}</p>
    <div class="request-list">
      {landing.breakdown.requests.map((item) => <span>{item}</span>)}
    </div>
  </div>
  <div class="cause-panel">
    <span>{landing.breakdown.realProblemTitle}</span>
    <p>{landing.breakdown.realProblem}</p>
    <strong>{landing.breakdown.closing}</strong>
  </div>
</section>
